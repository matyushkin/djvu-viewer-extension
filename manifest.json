{
  "manifest_version": 3,
  "name": "DjVu Viewer",
  "version": "0.1.0",
  "description": "Open DjVu files in your browser, powered by djvu-rs WebAssembly.",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["declarativeNetRequest", "storage"],
  "host_permissions": ["<all_urls>"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": ["viewer/*", "viewer/pkg/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "declarative_net_request": {
    "rule_resources": [{
      "id": "djvu_redirect",
      "enabled": true,
      "path": "rules/redirect_djvu.json"
    }]
  }
}
